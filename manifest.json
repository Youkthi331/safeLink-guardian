{
  "manifest_version": 3,
  "name": "SafeLink Guardian",
  "version": "1.0",
  "description": "Blocks phishing websites",

  "permissions": ["tabs"],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },
  "action": {
  "default_popup": "popup.html"
}
}